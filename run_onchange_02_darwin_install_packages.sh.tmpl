{{ if eq .chezmoi.os "darwin" -}}
#!/bin/bash

set -e

echo "📦 Installing and upgrading packages declaratively with brew bundle..."
echo "⚠️  Packages not in the list will be uninstalled (--cleanup)"

brew bundle --cleanup --upgrade --file=/dev/stdin <<EOF
{{ range .packages.darwin.taps -}}
tap {{ . | quote }}
{{ end -}}
{{ range .packages.darwin.brews -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.darwin.casks -}}
cask {{ . | quote }}
{{ end -}}
{{ range .packages.darwin.mas -}}
mas {{ .name | quote }}, id: {{ .id }}
{{ end -}}
EOF

echo "✅ Package installation complete!"
{{ end -}}
