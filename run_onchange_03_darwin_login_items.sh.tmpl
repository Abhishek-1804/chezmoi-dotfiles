{{ if eq .chezmoi.os "darwin" -}}
#!/bin/bash

set -e

desired=(
  "Ghostty:/Applications/Ghostty.app"
  "Arc:/Applications/Arc.app"
  "Notion:/Applications/Notion.app"
  "Zed:/Applications/Zed.app"
  "Mail:/System/Applications/Mail.app"
  "WhatsApp:/Applications/WhatsApp.app"
  "Raycast:/Applications/Raycast.app"
  "AeroSpace:/Applications/AeroSpace.app"
  "Hyperkey:/Applications/Hyperkey.app"
  "Scroll Reverser:/Applications/Scroll Reverser.app"
  "Wispr Flow:/Applications/Wispr Flow.app"
  "Amphetamine:/Applications/Amphetamine.app"
  "Google Drive:/Applications/Google Drive.app"
)

echo "🔑 Syncing login items..."

# Get current login item names
current=$(osascript -e 'tell application "System Events" to get the name of every login item')

# Add missing items
for entry in "${desired[@]}"; do
  name="${entry%%:*}"
  path="${entry#*:}"
  if [ -d "$path" ] && ! echo "$current" | grep -qF "$name"; then
    echo "  + Adding $name"
    osascript -e "tell application \"System Events\" to make login item at end with properties {path:\"$path\", hidden:false}" > /dev/null
  fi
done

# Remove items no longer desired (split on comma only to preserve multi-word names)
IFS=',' read -ra items <<< "$current"
for item in "${items[@]}"; do
  item=$(echo "$item" | xargs)  # trim surrounding whitespace
  [ -z "$item" ] && continue
  found=false
  for entry in "${desired[@]}"; do
    name="${entry%%:*}"
    [[ "$item" == "$name" ]] && found=true && break
  done
  if ! $found; then
    echo "  - Removing $item"
    osascript -e "tell application \"System Events\" to delete login item \"$item\""
  fi
done

echo "✅ Login items synced!"
{{ end -}}
